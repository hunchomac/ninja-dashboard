{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": []
    },
    {
      "route": "/*",
      "rewrite": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*.{svg,png,jpg,jpeg,gif}", "/css/*"]
  }
}